# =============================================================
# Identity Security Platform — Environment Template
# =============================================================
# Copy to .env and fill in real values BEFORE starting services.
# Real secrets should ultimately live in Infisical post-bootstrap.
# NEVER commit .env with real values — it is in .gitignore.
#
# Generate strong passwords:
#   openssl rand -base64 32
# Generate hex keys (32 chars):
#   openssl rand -hex 16
# =============================================================

# --- POSTGRESQL AUTH ---
POSTGRES_AUTH_USER=postgres
POSTGRES_AUTH_PASSWORD=CHANGE_ME_strong_postgres_password

# --- KEYCLOAK DATABASE (created by init script) ---
KC_DB_USER=keycloak_user
KC_DB_PASSWORD=CHANGE_ME_strong_keycloak_db_password

# --- INFISICAL DATABASE (created by init script) ---
INFISICAL_DB_USER=infisical_user
INFISICAL_DB_PASSWORD=CHANGE_ME_strong_infisical_db_password

# --- REDIS ---
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- KEYCLOAK ---
KEYCLOAK_HOSTNAME=sso.YOUR_DOMAIN.com
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=CHANGE_ME_strong_keycloak_admin_password
KC_REALM=platform

# --- INFISICAL ---
INFISICAL_HOSTNAME=secrets.YOUR_DOMAIN.com
# Exactly 32 hex chars: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=CHANGE_ME_32_hex_chars_here_xxxxx
# At least 32 chars: openssl rand -base64 32
INFISICAL_AUTH_SECRET=CHANGE_ME_jwt_signing_secret_min_32_chars

# --- SMTP RELAY (Microsoft 365) ---
SMTP_HOSTNAME=mail.YOUR_DOMAIN.com
SMTP_USERNAME=noreply@YOUR_DOMAIN.com
# App Password or OAuth2 Bearer Token (M365 requires Modern Auth)
SMTP_PASSWORD=CHANGE_ME_smtp_credential
SMTP_DOMAIN=YOUR_DOMAIN.com
SMTP_FROM=noreply@YOUR_DOMAIN.com
# Azure AD OAuth2 credentials (for XOAUTH2 upgrade path)
SMTP_TENANT_ID=CHANGE_ME_azure_tenant_id
SMTP_CLIENT_ID=CHANGE_ME_azure_client_id
SMTP_CLIENT_SECRET=CHANGE_ME_azure_client_secret

# --- CLOUDFLARE TUNNEL ---
# cloudflared tunnel create platform && cloudflared tunnel token platform
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_cloudflare_tunnel_token

# --- GRAFANA ---
GRAFANA_HOSTNAME=monitoring.YOUR_DOMAIN.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password
GRAFANA_OIDC_CLIENT_ID=grafana
GRAFANA_OIDC_CLIENT_SECRET=CHANGE_ME_grafana_oidc_secret

# --- BACKUP ---
BACKUP_DIR=/opt/backups/iam-platform
BACKUP_RETENTION_DAYS=30
# GPG symmetric passphrase for encrypted backups
BACKUP_ENCRYPTION_KEY=CHANGE_ME_gpg_passphrase_min_32_chars
